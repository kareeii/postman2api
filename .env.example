# ── Service ──────────────────────────────────────────
PORT=1930
DASHBOARD_PORT=1931

# ── Authentication ───────────────────────────────────
API_KEY=postman2api-secret-key
ENCRYPTION_KEY=change-this-to-a-random-32-char-hex-string

# ── Database ─────────────────────────────────────────
DATABASE_PATH=./data/postman2api.db

# ── Browser Automation ───────────────────────────────
BROWSER_ENGINE=camoufox
CAMOUFOX_HEADLESS=false
# Optional proxy for browser automation
# BATCHER_PROXY_URL=http://user:pass@host:port
